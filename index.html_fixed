<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sinatle Media | The Truth is Here</title>
    <!-- Google Fonts for Vintage Athletic/Brutalist vibe -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" type="image/png" href="/img/faviconlogo.png">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        bgOffWhite: '#EBE6D6', /* Vintage pale yellow/cream */
                        textDark: '#121212',  /* Rich black */
                        accentGreen: '#0B382A', /* Dark muted athletic green */
                    },
                    fontFamily: {
                        display: ['"Space Grotesk"', 'sans-serif'],
                        sans: ['"Space Grotesk"', 'sans-serif'],
                        body: ['"Space Grotesk"', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>
<body class="bg-white text-textDark font-body antialiased p-2 md:p-6 min-h-screen flex flex-col">
    <!-- Main Poster Frame -->
    <div class="border-[8px] md:border-[12px] border-textDark bg-bgOffWhite flex flex-col relative w-full overflow-hidden shadow-2xl">
        
        <!-- Header Banner -->
        <header class="border-b-[6px] md:border-b-[10px] border-textDark flex items-center justify-center p-4 md:p-8 bg-bgOffWhite">
            <h1 class="font-display text-[12vw] leading-[0.85] text-textDark tracking-normal m-0 text-center flex items-end justify-center w-full">
                SINATLE-MEDIA
            </h1>
        </header>

        <!-- Navigation Bar -->
        <nav class="bg-textDark text-bgOffWhite border-b-[6px] md:border-b-[10px] border-textDark">
            <div class="w-full px-4 md:px-12 py-3 md:py-4 flex flex-wrap justify-between items-center uppercase font-sans text-sm md:text-2xl tracking-widest font-medium">
                <a href="#about" class="hover:text-accentGreen transition-colors">About</a>
                <a href="#community" class="hover:text-accentGreen transition-colors">Community</a>
                <a href="#store" class="hover:text-accentGreen transition-colors">Merch</a>
                <a href="#news" class="hover:text-accentGreen transition-colors">Manifesto</a>
                <a href="#community" class="hover:text-accentGreen transition-colors">Support</a>
            </div>
        </nav>

        <!-- Hero Section (The Situation) -->
        <section id="about" class="grid grid-cols-1 lg:grid-cols-2 p-6 md:p-12 lg:p-16 gap-8 md:gap-16 border-b-[6px] md:border-b-[10px] border-textDark">
            <div class="flex flex-col justify-center">
                <h2 class="font-sans font-bold text-6xl md:text-8xl lg:text-[7.5rem] uppercase text-textDark leading-[0.9] tracking-tight m-0">
                    Protect The Truth, Defend Democracy
                </h2>
            </div>
            <div class="flex flex-col justify-end lg:pb-4">
                <p class="font-body text-xl md:text-2xl text-textDark mb-8 font-medium leading-relaxed max-w-2xl">
                    In Georgia, independent media is under severe threat. The truth is being actively silenced. 22 independent online outlets have united into a single, unignorable collective to fight back. We need you on the team.
                </p>
                <a href="#community" class="bg-accentGreen text-bgOffWhite px-10 py-5 font-sans uppercase text-2xl font-medium tracking-widest w-fit hover:bg-textDark transition-colors flex items-center gap-4 border-[3px] border-accentGreen">
                    FUND THE TRUTH
                </a>
            </div>
        </section>

        <!-- Hero Images -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-[10px] bg-textDark border-b-[6px] md:border-b-[10px] border-textDark p-4 md:p-[10px]">
            <img src="https://i.pinimg.com/736x/d0/9c/87/d09c87eed9537439c0a6cfbcf8a8a8f7.jpg" alt="Protest" class="w-full h-[400px] md:h-[600px] object-cover contrast-125 border-[4px] border-textDark">
            <img src="https://static.ffx.io/images/$zoom_0.467,$multiply_2,$ratio_1.5,$width_756,$x_70,$y_0/t_crop_custom/c_scale,w_620,q_88,f_auto/b02d6d15d795df60f7ae9a9b5b0d4c50d4a4aa15" alt="Megaphone" class="w-full h-[400px] md:h-[600px] object-cover contrast-125 border-[4px] border-textDark">
        </section>

        <!-- Subscriptions Section -->
        <section id="community" class="p-6 md:p-12 lg:p-16 border-b-[6px] md:border-b-[10px] border-textDark bg-bgOffWhite">
            <div class="flex flex-col md:flex-row justify-between items-end mb-12 border-b-[4px] border-textDark pb-6">
                <h2 class="font-sans font-bold text-5xl md:text-7xl uppercase text-textDark leading-none tracking-tight">
                    Don't Just Read. <br>Connect.
                </h2>
                <div class="bg-textDark text-bgOffWhite px-6 py-2 font-sans font-medium tracking-widest uppercase mt-6 md:mt-0">
                    >> Connection Protocol
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 max-w-6xl mx-auto" id="pricing-cards">
                <!-- Tier 1 -->
                <div class="border-[6px] border-textDark bg-bgOffWhite p-8 flex flex-col relative">
                    <h3 class="font-display text-5xl uppercase tracking-wider mb-2">Digital Access</h3>
                    <p class="font-body text-lg font-medium opacity-80 h-16">Support our journalism and fund our defense against legal threats.</p>
                    <div class="font-display text-8xl mb-8 border-y-[4px] border-textDark py-4 text-accentGreen flex items-start gap-2">
                        <span class="text-4xl mt-2">₾</span>15<span class="text-2xl font-sans self-end mb-3">/mo</span>
                    </div>
                    <ul class="space-y-4 mb-10 flex-grow font-sans font-medium text-xl uppercase tracking-widest">
                        <li class="flex items-center gap-4"><span class="text-textDark">X</span> Support 22 Outlets</li>
                        <li class="flex items-center gap-4"><span class="text-textDark">X</span> Ad-Free Reading</li>
                        <li class="flex items-center gap-4"><span class="text-textDark">X</span> Weekly Report</li>
                    </ul>
                    <button class="w-full py-5 font-sans font-bold bg-textDark text-bgOffWhite hover:bg-accentGreen transition-colors uppercase tracking-widest text-xl">Subscribe</button>
                </div>

                <!-- Tier 2 -->
                <div class="border-[6px] border-textDark bg-textDark text-bgOffWhite p-8 flex flex-col relative">
                    <div class="absolute -top-5 right-8 bg-bgOffWhite text-textDark font-sans font-bold px-4 py-1 border-[4px] border-textDark uppercase tracking-widest">The Gallery</div>
                    <h3 class="font-display text-5xl uppercase tracking-wider mb-2">Physical Access</h3>
                    <p class="font-body text-lg font-medium opacity-80 h-16">Immerse yourself. Be surrounded by like-minded people. Zero imposter syndrome.</p>
                    <div class="font-display text-8xl mb-8 border-y-[4px] border-bgOffWhite py-4 text-bgOffWhite flex items-start gap-2">
                        <span class="text-4xl mt-2">₾</span>45<span class="text-2xl font-sans self-end mb-3">/mo</span>
                    </div>
                    <ul class="space-y-4 mb-10 flex-grow font-sans font-medium text-xl uppercase tracking-widest">
                        <li class="flex items-center gap-4"><span class="text-accentGreen">X</span> Live Screenings</li>
                        <li class="flex items-center gap-4"><span class="text-accentGreen">X</span> In-Person Debates</li>
                        <li class="flex items-center gap-4"><span class="text-accentGreen">X</span> Panel Discussions</li>
                    </ul>
                    <button class="w-full py-5 font-sans font-bold bg-bgOffWhite text-textDark hover:bg-accentGreen hover:text-bgOffWhite hover:border-bgOffWhite border-[4px] border-transparent transition-colors uppercase tracking-widest text-xl">Join</button>
                </div>
            </div>
        </section>

        <!-- Merch Section -->
        <section id="store" class="p-6 md:p-12 lg:p-16 border-b-[6px] md:border-b-[10px] border-textDark bg-bgOffWhite relative">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 border-b-[4px] border-textDark pb-6">
                <h2 class="font-sans font-bold text-6xl md:text-8xl uppercase text-textDark leading-none tracking-tight">
                    Wear The<br>Message.
                </h2>
                <div class="mt-6 md:mt-0 text-right">
                    <p class="font-body text-xl font-medium max-w-sm mb-4">Clothing that communicates our truth and acts as a walking billboard.</p>
                    <span class="bg-accentGreen text-bgOffWhite px-6 py-2 font-sans font-medium tracking-widest uppercase">
                        100% PROFIT TO THE ORG.
                    </span>
                </div>
            </div>

            <div id="merch-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
                
                <!-- Product 1 -->
                <div class="border-[6px] border-textDark bg-bgOffWhite flex flex-col group p-4 cursor-pointer transition-all duration-300" onclick="toggleProductExpansion(this)">
                    <div class="aspect-[4/5] border-[4px] border-textDark relative overflow-hidden bg-textDark flex items-center justify-center mb-6">
                        <img src="https://i.pinimg.com/1200x/31/37/12/3137122817418a08c0d9fc8fe778ee7d.jpg" alt="Tee" class="object-cover w-full h-full opacity-90 group-hover:opacity-100 transition-all duration-500 transform group-hover:scale-105">
                        <button class="absolute bottom-4 left-1/2 transform -translate-x-1/2 bg-accentGreen text-bgOffWhite px-6 py-3 font-sans font-bold uppercase tracking-widest border-[3px] border-bgOffWhite z-30 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap" onclick="addToCart(event)">Add to Cart</button>
                    </div>
                    <div>
                        <h3 class="font-display text-4xl uppercase tracking-wider leading-none">"Lumina" Tee</h3>
                        <p class="font-body text-sm font-medium mt-2 text-textDark uppercase">Heavyweight Cotton</p>
                        <div class="font-display text-4xl mt-4 text-accentGreen">₾65</div>
                    </div>
                    <!-- Expanded Options Segment -->
                    <div class="expandable-content hidden flex flex-col mt-4 border-t-[4px] border-textDark pt-4 cursor-default" onclick="event.stopPropagation()">
                        <label class="font-sans font-bold uppercase tracking-widest text-sm mb-2">Select Size</label>
                        <div class="flex gap-2 mb-4">
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">S</button>
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">M</button>
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">L</button>
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">XL</button>
                        </div>
                        <button class="w-full bg-accentGreen text-bgOffWhite px-6 py-3 font-sans font-bold uppercase tracking-widest border-[3px] border-textDark hover:bg-textDark transition-colors" onclick="addToCart(event)">Confirm Add to Cart</button>
                    </div>
                </div>

                <!-- Product 2 -->
                <div class="border-[6px] border-textDark bg-bgOffWhite flex flex-col group p-4 cursor-pointer transition-all duration-300" onclick="toggleProductExpansion(this)">
                    <div class="aspect-[4/5] border-[4px] border-textDark relative overflow-hidden bg-textDark flex items-center justify-center mb-6">
                        <img src="https://i.pinimg.com/736x/09/65/6b/09656b0fc9756fd788b4b3db6874e342.jpg" alt="Tote" class="object-cover w-full h-full opacity-90 group-hover:opacity-100 transition-all duration-500 transform group-hover:scale-105">
                        <button class="absolute bottom-4 left-1/2 transform -translate-x-1/2 bg-accentGreen text-bgOffWhite px-6 py-3 font-sans font-bold uppercase tracking-widest border-[3px] border-bgOffWhite z-30 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap" onclick="addToCart(event)">Add to Cart</button>
                    </div>
                    <div>
                        <h3 class="font-display text-4xl uppercase tracking-wider leading-none">"Echo" Tote</h3>
                        <p class="font-body text-sm font-medium mt-2 text-textDark uppercase">Everyday Protest Gear</p>
                        <div class="font-display text-4xl mt-4 text-accentGreen">₾40</div>
                    </div>
                    <!-- Expanded Options Segment -->
                    <div class="expandable-content hidden flex flex-col mt-4 border-t-[4px] border-textDark pt-4 cursor-default" onclick="event.stopPropagation()">
                        <label class="font-sans font-bold uppercase tracking-widest text-sm mb-2">Select Color</label>
                        <div class="flex gap-2 mb-4">
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">Cream</button>
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">Black</button>
                        </div>
                        <button class="w-full bg-accentGreen text-bgOffWhite px-6 py-3 font-sans font-bold uppercase tracking-widest border-[3px] border-textDark hover:bg-textDark transition-colors" onclick="addToCart(event)">Confirm Add to Cart</button>
                    </div>
                </div>

                <!-- Product 3 -->
                <div class="border-[6px] border-textDark bg-bgOffWhite flex flex-col group p-4 relative cursor-pointer transition-all duration-300" onclick="toggleProductExpansion(this)">
                    <div class="absolute top-0 right-0 bg-textDark text-bgOffWhite font-sans font-bold px-6 py-2 border-b-[6px] border-l-[6px] border-textDark z-10 uppercase tracking-widest text-sm">Bestseller</div>
                    <div class="aspect-[4/5] border-[4px] border-textDark relative overflow-hidden bg-textDark flex items-center justify-center mb-6">
                        <img src="https://i.pinimg.com/1200x/1d/09/f0/1d09f070d167c982f9ae407bb0237e69.jpg" alt="Mug" class="object-cover w-full h-full opacity-90 group-hover:opacity-100 transition-all duration-500 transform group-hover:scale-105">
                        <button class="absolute bottom-4 left-1/2 transform -translate-x-1/2 bg-accentGreen text-bgOffWhite px-6 py-3 font-sans font-bold uppercase tracking-widest border-[3px] border-bgOffWhite z-30 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap" onclick="addToCart(event)">Add to Cart</button>
                    </div>
                    <div>
                        <h3 class="font-display text-4xl uppercase tracking-wider leading-none">Morning Mug</h3>
                        <p class="font-body text-sm font-medium mt-2 text-textDark uppercase">Matte Black</p>
                        <div class="font-display text-4xl mt-4 text-accentGreen">₾35</div>
                    </div>
                    <!-- Expanded Options Segment -->
                    <div class="expandable-content hidden flex flex-col mt-4 border-t-[4px] border-textDark pt-4 cursor-default" onclick="event.stopPropagation()">
                        <label class="font-sans font-bold uppercase tracking-widest text-sm mb-2">Quantity</label>
                        <div class="flex gap-2 mb-4">
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">1</button>
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">2</button>
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">4</button>
                        </div>
                        <button class="w-full bg-accentGreen text-bgOffWhite px-6 py-3 font-sans font-bold uppercase tracking-widest border-[3px] border-textDark hover:bg-textDark transition-colors" onclick="addToCart(event)">Confirm Add to Cart</button>
                    </div>
                </div>

                <!-- Classic Logo Hoodie -->
                <div class="border-[6px] border-textDark bg-bgOffWhite flex flex-col group p-4 cursor-pointer transition-all duration-300" onclick="toggleProductExpansion(this)">
                    <div class="aspect-[4/5] border-[4px] border-textDark relative overflow-hidden bg-textDark flex items-center justify-center mb-6">
                        <img src="https://i.pinimg.com/1200x/d0/21/06/d02106563a06c931b808a7bd801dd99a.jpg" alt="Classic Logo Hoodie" class="object-cover w-full h-full opacity-90 group-hover:opacity-100 transition-all duration-500 transform group-hover:scale-105">
                        <button class="absolute bottom-4 left-1/2 transform -translate-x-1/2 bg-accentGreen text-bgOffWhite px-6 py-3 font-sans font-bold uppercase tracking-widest border-[3px] border-bgOffWhite z-30 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap" onclick="addToCart(event)">Add to Cart</button>
                    </div>
                    <div>
                        <h3 class="font-display text-4xl uppercase tracking-wider leading-none">Classic Logo Hoodie</h3>
                        <p class="font-body text-sm font-medium mt-2 text-textDark uppercase">Heavyweight Boxy Fit</p>
                        <div class="font-display text-4xl mt-4 text-accentGreen">₾120</div>
                    </div>
                    <!-- Expanded Options Segment -->
                    <div class="expandable-content hidden flex flex-col mt-4 border-t-[4px] border-textDark pt-4 cursor-default" onclick="event.stopPropagation()">
                        <label class="font-sans font-bold uppercase tracking-widest text-sm mb-2">Select Size</label>
                        <div class="flex gap-2 mb-4">
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">S</button>
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">M</button>
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">L</button>
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">XL</button>
                        </div>
                        <button class="w-full bg-accentGreen text-bgOffWhite px-6 py-3 font-sans font-bold uppercase tracking-widest border-[3px] border-textDark hover:bg-textDark transition-colors" onclick="addToCart(event)">Confirm Add to Cart</button>
                    </div>
                </div>

                <!-- Protest Utility Beanie -->
                <div class="border-[6px] border-textDark bg-bgOffWhite flex flex-col group p-4 cursor-pointer transition-all duration-300" onclick="toggleProductExpansion(this)">
                    <div class="aspect-[4/5] border-[4px] border-textDark relative overflow-hidden bg-textDark flex items-center justify-center mb-6">
                        <img src="https://i.pinimg.com/736x/ad/9c/80/ad9c804ff247daba9807806b9c3f585b.jpg" alt="Protest Utility Beanie" class="object-cover w-full h-full opacity-90 group-hover:opacity-100 transition-all duration-500 transform group-hover:scale-105">
                        <button class="absolute bottom-4 left-1/2 transform -translate-x-1/2 bg-accentGreen text-bgOffWhite px-6 py-3 font-sans font-bold uppercase tracking-widest border-[3px] border-bgOffWhite z-30 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap" onclick="addToCart(event)">Add to Cart</button>
                    </div>
                    <div>
                        <h3 class="font-display text-4xl uppercase tracking-wider leading-none">Protest Utility Beanie</h3>
                        <p class="font-body text-sm font-medium mt-2 text-textDark uppercase">100% Cotton Rib knit</p>
                        <div class="font-display text-4xl mt-4 text-accentGreen">₾35</div>
                    </div>
                    <!-- Expanded Options Segment -->
                    <div class="expandable-content hidden flex flex-col mt-4 border-t-[4px] border-textDark pt-4 cursor-default" onclick="event.stopPropagation()">
                        <label class="font-sans font-bold uppercase tracking-widest text-sm mb-2">Select Color</label>
                        <div class="flex gap-2 mb-4">
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">Black</button>
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">Orange</button>
                        </div>
                        <button class="w-full bg-accentGreen text-bgOffWhite px-6 py-3 font-sans font-bold uppercase tracking-widest border-[3px] border-textDark hover:bg-textDark transition-colors" onclick="addToCart(event)">Confirm Add to Cart</button>
                    </div>
                </div>

                <!-- Press Badge Lanyard -->
                <div class="border-[6px] border-textDark bg-bgOffWhite flex flex-col group p-4 cursor-pointer transition-all duration-300" onclick="toggleProductExpansion(this)">
                    <div class="aspect-[4/5] border-[4px] border-textDark relative overflow-hidden bg-textDark flex items-center justify-center mb-6">
                        <img src="https://i.pinimg.com/1200x/7f/bc/80/7fbc8030a6bca3e34d66cb221f1f0d0f.jpg" alt="Press Badge Lanyard" class="object-cover w-full h-full opacity-90 group-hover:opacity-100 transition-all duration-500 transform group-hover:scale-105">
                        <button class="absolute bottom-4 left-1/2 transform -translate-x-1/2 bg-accentGreen text-bgOffWhite px-6 py-3 font-sans font-bold uppercase tracking-widest border-[3px] border-bgOffWhite z-30 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap" onclick="addToCart(event)">Add to Cart</button>
                    </div>
                    <div>
                        <h3 class="font-display text-4xl uppercase tracking-wider leading-none">Press Badge Lanyard</h3>
                        <p class="font-body text-sm font-medium mt-2 text-textDark uppercase">Woven Nylon with Metal Clip</p>
                        <div class="font-display text-4xl mt-4 text-accentGreen">₾20</div>
                    
                    </div>
                    <!-- Expanded Options Segment -->
                    <div class="expandable-content hidden flex flex-col mt-4 border-t-[4px] border-textDark pt-4 cursor-default" onclick="event.stopPropagation()">
                        <label class="font-sans font-bold uppercase tracking-widest text-sm mb-2">Select Color</label>
                        <div class="flex gap-2 mb-4 flex-wrap">
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">Olive</button>
                            <button class="size-btn flex-1 border-[3px] border-textDark px-3 py-2 font-sans font-bold hover:bg-textDark hover:text-bgOffWhite transition-colors" onclick="selectSize(event, this)">Black</button>
                        </div>
                        <button class="w-full bg-accentGreen text-bgOffWhite px-6 py-3 font-sans font-bold uppercase tracking-widest border-[3px] border-textDark hover:bg-textDark transition-colors" onclick="addToCart(event)">Confirm Add to Cart</button>
                    </div>
                </div>
                </div>

                <!-- Sinatle Zine Vol. 1 -->
                <div class="border-[6px] border-textDark bg-bgOffWhite flex flex-col group p-4 cursor-pointer transition-all duration-300" onclick="toggleProductExpansion(this)">
